<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en-GB</string>
	<key>CFBundleDisplayName</key>
	<string>TruckNav Pro</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>3.7.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
		<string>remote-notification</string>
		<string>audio</string>
	</array>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>TruckNav Pro uses your location for real-time route navigation and truck-specific directions</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Background location is required to continue navigation and monitor your route while TruckNav Pro is in the background</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>Background location is required to continue navigation and monitor your route while TruckNav Pro is in the background</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Microphone access is needed for hands-free voice commands to report traffic incidents during navigation</string>
	<key>NSCameraUsageDescription</key>
	<string>Camera access is used for the augmented reality navigation overlay</string>
	<key>NSMotionUsageDescription</key>
	<string>Motion data improves navigation accuracy and detects vehicle orientation</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Bluetooth is used to connect to CarPlay and transmit navigation voice through your vehicle audio system</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>Bluetooth is used to connect to CarPlay and transmit navigation voice through your vehicle audio system</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSBonjourServices</key>
	<array>
		<string>_http._tcp</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>api.tomtom.com</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.2</string>
			</dict>
			<key>router.hereapi.com</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.2</string>
			</dict>
		</dict>
	</dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>trucknavpro</string>
			</array>
		</dict>
	</dict>
	<key>CPTemplateApplicationSceneSessionRoleApplication</key>
	<array>
		<dict>
			<key>UISceneClassName</key>
			<string>CPTemplateApplicationScene</string>
			<key>UISceneConfigurationName</key>
			<string>CarPlay Configuration</string>
			<key>UISceneDelegateClassName</key>
			<string>$(PRODUCT_MODULE_NAME).CarPlaySceneDelegate</string>
		</dict>
	</array>
</dict>
</plist>
