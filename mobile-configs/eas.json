{
  "cli": {
    "version": ">= 5.9.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "aab"
      }
    },
    "china": {
      "env": {
        "EXPO_PROFILE": "china"
      },
      "android": {
        "buildType": "apk",
        "image": "latest"
      },
      "distribution": "store"
    },
    "tencent": {
      "extends": "china",
      "env": {
        "EXPO_PROFILE": "china",
        "TARGET_STORE": "tencent"
      }
    },
    "huawei": {
      "extends": "china", 
      "env": {
        "EXPO_PROFILE": "china",
        "TARGET_STORE": "huawei"
      }
    },
    "xiaomi": {
      "extends": "china",
      "env": {
        "EXPO_PROFILE": "china", 
        "TARGET_STORE": "xiaomi"
      }
    },
    "baidu": {
      "extends": "china",
      "env": {
        "EXPO_PROFILE": "china",
        "TARGET_STORE": "baidu"
      }
    },
    "google-play": {
      "android": {
        "buildType": "aab"
      },
      "env": {
        "TARGET_STORE": "google-play"
      }
    }
  },
  "submit": {
    "production": {},
    "china": {
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}