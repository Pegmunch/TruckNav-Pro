{
  "name": "trucknav-pro-mobile",
  "version": "1.0.0",
  "description": "TruckNav Pro - Mobile App for Truck Navigation",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:china": "eas build --platform android --profile china",
    "build:tencent": "eas build --platform android --profile tencent",
    "build:huawei": "eas build --platform android --profile huawei", 
    "build:xiaomi": "eas build --platform android --profile xiaomi",
    "build:baidu": "eas build --platform android --profile baidu",
    "build:google": "eas build --platform android --profile google-play",
    "submit:china": "eas submit --platform android --profile china",
    "preview": "eas build --profile preview"
  },
  "dependencies": {
    "@expo/vector-icons": "^13.0.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@react-native-async-storage/async-storage": "1.19.3",
    "@react-native-community/geolocation": "^3.0.6",
    "@tanstack/react-query": "^5.8.4",
    "axios": "^1.6.0",
    "expo": "~49.0.15",
    "expo-font": "~11.4.0",
    "expo-location": "~16.1.0",
    "expo-notifications": "~0.20.1",
    "expo-splash-screen": "~0.20.5",
    "expo-status-bar": "~1.6.0",
